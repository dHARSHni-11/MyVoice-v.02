# ═══════════════════════════════════════════════════════════════════
#  Backend .env.production — Railway Deployment Template
# ═══════════════════════════════════════════════════════════════════
#
#  Copy this file and fill in actual values.
#  On Railway, set these as environment variables in the service dashboard.
#  Variables prefixed with ${{...}} use Railway's variable reference syntax.
#

# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Railway MySQL (auto-injected by Railway MySQL plugin) ──────────
MYSQL_HOST=${{MySQL.MYSQLHOST}}
MYSQL_PORT=${{MySQL.MYSQLPORT}}
MYSQL_USER=${{MySQL.MYSQLUSER}}
MYSQL_PASSWORD=${{MySQL.MYSQLPASSWORD}}
MYSQL_DATABASE=${{MySQL.MYSQLDATABASE}}

# ── Microservice URLs (Railway internal networking) ────────────────
# These use Railway's private network — no public exposure needed.
NLP_SERVICE_URL=http://nlp-service.railway.internal:${{nlp-service.PORT}}
CV_SERVICE_URL=http://cv-service.railway.internal:${{cv-service.PORT}}

# ── Frontend URL (for CORS) ───────────────────────────────────────
# Comma-separated if you have preview + production URLs
FRONTEND_URL=https://frontend-production-xxxx.up.railway.app

# ── Authentication ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# ── External APIs ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── Email (optional) ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password
